---
import type { TemplateSiteSettings } from "../template/posts";

interface Props {
  settings: TemplateSiteSettings;
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: "website" | "article";
}

const { settings, title, description, canonical, image, type = "website" } = Astro.props;
const pageTitle = title ? `${title} | ${settings.title}` : settings.title;
const pageDescription = description ?? settings.description;
const canonicalUrl = canonical ?? settings.canonicalUrl;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    {image && <meta property="og:image" content={new URL(image, settings.canonicalUrl).toString()} />}
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    <meta name="theme-color" content={settings.theme.accent} />
    <style define:vars={{ accent: settings.theme.accent, background: settings.theme.background, text: settings.theme.text }}>
      :root { color-scheme: light; font-family: ui-serif, Georgia, Cambria, "Times New Roman", serif; background: var(--background); color: var(--text); }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--background); color: var(--text); }
      a { color: inherit; }
      .shell { width: min(100% - 2rem, 72rem); margin-inline: auto; }
      header { border-bottom: 1px solid color-mix(in srgb, var(--text) 15%, transparent); }
      header .shell { min-height: 4.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; }
      .brand { font: 700 1.05rem/1 ui-sans-serif, system-ui, sans-serif; text-decoration: none; }
      nav { display: flex; gap: 1.25rem; font: 600 .875rem/1 ui-sans-serif, system-ui, sans-serif; }
      main { min-height: calc(100vh - 10rem); }
      footer { border-top: 1px solid color-mix(in srgb, var(--text) 15%, transparent); padding: 2rem 0; color: color-mix(in srgb, var(--text) 65%, transparent); font: .875rem/1.5 ui-sans-serif, system-ui, sans-serif; }
      :global(.eyebrow) { color: var(--accent); text-transform: uppercase; letter-spacing: .08em; font: 700 .75rem/1.3 ui-sans-serif, system-ui, sans-serif; }
      :global(.prose) { font-size: clamp(1.05rem, 2vw, 1.2rem); line-height: 1.8; }
      :global(.prose img) { max-width: 100%; height: auto; border-radius: .4rem; }
      :global(.prose pre) { overflow-x: auto; padding: 1rem; background: #f4f4f5; border-radius: .4rem; }
      :global(.prose a) { color: var(--accent); text-underline-offset: .18em; }
      @media (max-width: 36rem) { header .shell { align-items: flex-start; flex-direction: column; padding-block: 1rem; } }
      @media (prefers-reduced-motion: reduce) { *, *::before, *::after { scroll-behavior: auto !important; transition-duration: 0.01ms !important; } }
    </style>
  </head>
  <body>
    <header>
      <div class="shell">
        <a class="brand" href={base}>{settings.title}</a>
        <nav aria-label="Primary">
          {settings.navigation.map((item) => <a href={item.href.startsWith("/") ? `${base}${item.href.slice(1)}` : item.href}>{item.label}</a>)}
          <a href={`${base}search/`}>Search</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer><div class="shell">Published independently by {settings.author.name}.</div></footer>
  </body>
</html>
