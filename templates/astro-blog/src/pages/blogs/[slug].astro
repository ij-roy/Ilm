---
import { getBlogUrl, getPublishedPosts, getSiteSettings } from "../../template/posts";

export async function getStaticPaths() {
  const settings = await getSiteSettings();
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post, settings } }));
}

const { post, settings } = Astro.props;
const destination = getBlogUrl(settings, post.slug, import.meta.env.BASE_URL);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0;url=${destination}`} />
    <link rel="canonical" href={new URL(destination, settings.canonicalUrl).toString()} />
    <title>Moved | {settings.title}</title>
  </head>
  <body><p>This blog moved to <a href={destination}>{destination}</a>.</p></body>
</html>
