---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getSiteSettings } from "../template/posts";
const settings = await getSiteSettings();
---

<SiteLayout settings={settings} title="Search" description={`Search ${settings.title}`}>
  <section class="search shell">
    <p class="eyebrow">Archive</p>
    <h1>Search</h1>
    <label for="search-input">Search published blogs</label>
    <input type="search" id="search-input" autocomplete="off" />
    <p id="search-status" role="status">Loading search index…</p>
    <ol id="search-results"></ol>
  </section>
  <script is:inline define:vars={{ base: import.meta.env.BASE_URL, blogPath: settings.blogPath }}>
    const input = document.querySelector("#search-input");
    const status = document.querySelector("#search-status");
    const results = document.querySelector("#search-results");
    let index = [];

    function render(matches) {
      results.replaceChildren();
      for (const post of matches) {
        const item = document.createElement("li");
        const link = document.createElement("a");
        const description = document.createElement("p");
        link.href = `${base}${blogPath}/${encodeURIComponent(post.slug)}/`;
        link.textContent = post.title;
        description.textContent = post.description;
        item.append(link, description);
        results.append(item);
      }
      status.textContent = matches.length ? `${matches.length} result${matches.length === 1 ? "" : "s"}` : "No results found.";
    }

    fetch(`${base}search.json`)
      .then((response) => {
        if (!response.ok) throw new Error("Search index failed");
        return response.json();
      })
      .then((data) => {
        index = Array.isArray(data) ? data : [];
        status.textContent = "Type to search.";
      })
      .catch(() => { status.textContent = "Search is unavailable right now."; });

    input.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      if (!query) { results.replaceChildren(); status.textContent = "Type to search."; return; }
      render(index.filter((post) => `${post.title} ${post.description} ${post.body}`.toLowerCase().includes(query)));
    });
  </script>
  <style>
    .search { max-width: 48rem; padding-block: clamp(3rem, 8vw, 7rem); }
    h1 { margin: .5rem 0 2rem; font-size: clamp(3rem, 8vw, 5rem); }
    label { display: block; margin-bottom: .5rem; font: 600 .875rem/1.4 ui-sans-serif, system-ui, sans-serif; }
    input { width: 100%; border: 1px solid color-mix(in srgb, var(--text) 25%, transparent); border-radius: .3rem; padding: .9rem 1rem; font: 1rem/1.4 ui-sans-serif, system-ui, sans-serif; }
    input:focus { outline: 3px solid color-mix(in srgb, var(--accent) 30%, transparent); border-color: var(--accent); }
    #search-status { color: color-mix(in srgb, var(--text) 60%, transparent); font: .875rem/1.5 ui-sans-serif, system-ui, sans-serif; }
    ol { list-style: none; padding: 0; }
    li { padding: 1.5rem 0; border-top: 1px solid color-mix(in srgb, var(--text) 15%, transparent); }
    li a { font-size: 1.35rem; font-weight: 700; }
  </style>
</SiteLayout>
