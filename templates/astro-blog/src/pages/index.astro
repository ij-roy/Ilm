---
import { getPublishedPosts } from "../template/posts";
import { getSeoConfigPath } from "../template/posts";

import { readFile } from "node:fs/promises";

const posts = await getPublishedPosts();

// Dynamically check and read the user's repo config/seo.ts at build time
let googleAnalyticsId: string | undefined = undefined;
try {
  const content = await readFile(getSeoConfigPath(), "utf-8");
  const match = content.match(/googleAnalyticsId:\s*["']([^"']+)["']/);
  if (match && match[1]) {
    googleAnalyticsId = match[1];
  }
} catch {
  // Graceful fallback if config file is not found (e.g. template build inside Ilm monorepo)
  googleAnalyticsId = undefined;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Ilm Starter</title>
    <meta name="description" content="A user-owned Ilm blog starter." />

    {googleAnalyticsId && (
      <>
        <script type="text/javascript" is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}></script>
        <script type="text/javascript" is:inline define:vars={{ googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', googleAnalyticsId);
        </script>
      </>
    )}
  </head>
  <body>
    <main>
      <h1>Ilm Starter</h1>
      <p>Static output generated from the user-owned repository structure.</p>
      <p><a href="/search/">🔍 Search Blog</a></p>
      {googleAnalyticsId && (
        <p style="color: #666; font-size: 0.85rem;">
          Google Analytics: Active (<code>{googleAnalyticsId}</code>)
        </p>
      )}
      <ul>
        {posts.map((post) => <li><a href={`/posts/${post.slug}/`}>{post.title}</a></li>)}
      </ul>
    </main>
  </body>
</html>
