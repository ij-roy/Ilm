---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getBlogUrl, getPublishedPosts, getSiteSettings } from "../template/posts";

const settings = await getSiteSettings();
const posts = (await getPublishedPosts()).sort((a, b) => b.publishedAt.getTime() - a.publishedAt.getTime());
const base = import.meta.env.BASE_URL;
---

<SiteLayout settings={settings}>
  <section class="hero shell">
    <p class="eyebrow">Independent publishing</p>
    <h1>{settings.title}</h1>
    <p>{settings.description}</p>
  </section>
  <section class="archive shell" aria-labelledby="latest-heading">
    <h2 id="latest-heading">Latest writing</h2>
    {posts.length === 0 ? <p>No blogs have been published yet.</p> : (
      <ol>
        {posts.map((post) => (
          <li>
            <time datetime={post.publishedAt.toISOString()}>{post.publishedAt.toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" })}</time>
            <div><a href={getBlogUrl(settings, post.slug, base)}>{post.title}</a><p>{post.description}</p></div>
          </li>
        ))}
      </ol>
    )}
  </section>
  <style>
    .hero { padding-block: clamp(4rem, 12vw, 10rem); }
    .hero h1 { max-width: 14ch; margin: .75rem 0 1.25rem; font-size: clamp(3.5rem, 10vw, 7.5rem); line-height: .9; letter-spacing: 0; }
    .hero > p:last-child { max-width: 38rem; color: color-mix(in srgb, var(--text) 68%, transparent); font-size: 1.35rem; line-height: 1.55; }
    .archive { padding-bottom: 8rem; }
    .archive h2 { font: 700 .8rem/1 ui-sans-serif, system-ui, sans-serif; text-transform: uppercase; letter-spacing: .08em; }
    ol { list-style: none; padding: 0; margin: 2rem 0 0; border-top: 1px solid color-mix(in srgb, var(--text) 15%, transparent); }
    li { display: grid; grid-template-columns: 10rem 1fr; gap: 2rem; padding: 2rem 0; border-bottom: 1px solid color-mix(in srgb, var(--text) 15%, transparent); }
    time { color: color-mix(in srgb, var(--text) 60%, transparent); font: .85rem/1.5 ui-sans-serif, system-ui, sans-serif; }
    li a { font-size: clamp(1.5rem, 3vw, 2.4rem); font-weight: 700; text-decoration-thickness: .08em; text-underline-offset: .15em; }
    li p { color: color-mix(in srgb, var(--text) 68%, transparent); line-height: 1.6; }
    @media (max-width: 40rem) { li { grid-template-columns: 1fr; gap: .5rem; } }
  </style>
</SiteLayout>
